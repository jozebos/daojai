---
import AppLayout from "@/layouts/AppLayout.astro";

const TOP_SIGNS = [
  { symbol: "♌", name: "สิงห์", hint: "โชคลาภมาเยือน", color: "#F59E0B" },
  { symbol: "♏", name: "พิจิก", hint: "ความรักสดใส", color: "#C4B5FD" },
  { symbol: "♓", name: "มีน", hint: "การงานก้าวหน้า", color: "#7DD3FC" },
];

const R2_BASE = "https://pub-86244ba66c1247a7850218ca7cc8a538.r2.dev/tarot";
const FAN_CARDS = [
  { id: "major-00-fool", rotate: -18, ty: 16 },
  { id: "major-01-magician", rotate: -10, ty: 6 },
  { id: "major-02-high-priestess", rotate: -3, ty: 0 },
  { id: "major-17-star", rotate: 0, ty: -4 },
  { id: "major-06-lovers", rotate: 3, ty: 0 },
  { id: "major-19-sun", rotate: 10, ty: 6 },
  { id: "major-21-world", rotate: 18, ty: 16 },
];

const SPREADS = [
  {
    href: "/tarot/daily",
    title: "ไพ่ประจำวัน",
    subtitle: "Daily Card",
    desc: "จับไพ่ 1 ใบ ดูว่าจักรวาลอยากบอกอะไรคุณ",
    icon: "☀️",
    accent: "gold",
  },
  {
    href: "/tarot/3-card",
    title: "ไพ่ 3 ใบ",
    subtitle: "3-Card Spread",
    desc: "เปิดอดีต ปัจจุบัน อนาคต ใน 3 ใบ",
    icon: "🃏",
    accent: "lavender",
  },
  {
    href: "/horoscope",
    title: "ดวงรายวัน",
    subtitle: "Daily Horoscope",
    desc: "เลือกราศีดูดวงวันนี้ ครบ 12 ราศี",
    icon: "🔮",
    accent: "sky",
  },
];
---

<AppLayout title="เดาใจ — เดาใจเขา เดาใจคุณ | DaoJai">
  <div class="relative overflow-hidden">

    <div class="star-field-home" aria-hidden="true">
      <div class="stars-home-sm"></div>
      <div class="stars-home-md"></div>
    </div>

    <div class="noise-home" aria-hidden="true"></div>

    <div class="relative z-10">

      <section class="hero-section flex flex-col items-center justify-center text-center max-w-4xl mx-auto relative">
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-glow-secondary" aria-hidden="true"></div>

        <h1 class="hero-title font-display font-bold text-5xl sm:text-6xl md:text-7xl text-accent-gold leading-none animate-[fade-in-up_0.6s_ease-out_both] relative z-10">
          เดาใจ
        </h1>

        <p class="text-lg sm:text-xl md:text-2xl text-lavender-300 font-display mt-3 mb-1 animate-[fade-in-up_0.6s_ease-out_0.12s_both] relative z-10">
          เพื่อนสนิทที่รู้เรื่องดวง
        </p>
        <p class="text-xs sm:text-sm text-text-muted tracking-widest uppercase animate-[fade-in-up_0.6s_ease-out_0.2s_both] relative z-10">
          Read the stars · Hear your heart
        </p>

        <div class="card-fan-container mt-10 sm:mt-14 mb-8 animate-[fade-in-up_0.8s_ease-out_0.3s_both] relative z-10">
          <div class="card-fan flex items-end justify-center">
            {FAN_CARDS.map((c, i) => (
              <div
                class="card-fan-item"
                style={`--fan-rotate: ${c.rotate}deg; --fan-ty: ${c.ty}px; --fan-delay: ${i * 0.08}s; --fan-base-transform: rotate(${c.rotate}deg) translateY(${c.ty}px); transform: rotate(${c.rotate}deg) translateY(${c.ty}px); z-index: ${7 - Math.abs(i - 3)}; animation: fan-float 4s ease-in-out infinite; animation-delay: ${i * 0.3}s; margin-left: ${i > 0 ? '-16px' : '0'};`}
              >
                <img
                  src={`${R2_BASE}/${c.id}.webp`}
                  alt=""
                  loading="lazy"
                  width="110"
                  height="165"
                />
              </div>
            ))}
          </div>
        </div>

        <a
          href="#spreads"
          class="cta-button inline-flex items-center gap-2 px-8 py-3.5 rounded-full font-display font-bold text-base sm:text-lg animate-[fade-in-up_0.6s_ease-out_0.45s_both] relative z-10"
        >
          เริ่มดูดวงเลย
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>

        <div class="scroll-indicator mt-10 animate-[fade-in-up_0.6s_ease-out_0.6s_both]" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted/50">
            <path d="M12 5v14M5 12l7 7 7-7" />
          </svg>
        </div>
      </section>

      <section id="spreads" class="max-w-3xl mx-auto py-16 sm:py-20 relative">
        <div class="spread-section-glow" aria-hidden="true"></div>

        <h2 class="font-display font-bold text-xl sm:text-2xl text-lavender-100 text-center mb-3 animate-[fade-in-up_0.6s_ease-out_both]">
          เลือกแบบดูดวง
        </h2>
        <p class="text-text-muted text-sm text-center mb-10 animate-[fade-in-up_0.6s_ease-out_0.1s_both]">
          เลือกวิธีที่ใช่ แล้วปล่อยให้จักรวาลพูดกับคุณ
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5">
          {SPREADS.map((s, i) => (
            <a
              href={s.href}
              class={`spread-card spread-card--${s.accent} group`}
              style={`animation: fade-in-up 0.6s ease-out ${0.15 + i * 0.1}s both;`}
            >
              <div class="spread-card-glow" aria-hidden="true"></div>
              <span class="spread-card-emoji">{s.icon}</span>
              <h3 class="font-display font-bold text-base sm:text-lg text-lavender-100 group-hover:text-accent-gold transition-colors">
                {s.title}
              </h3>
              <span class="text-[10px] text-text-muted tracking-wide uppercase">{s.subtitle}</span>
              <p class="text-xs text-text-muted/70 mt-2 leading-relaxed">{s.desc}</p>
              <span class="spread-card-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="max-w-3xl mx-auto pb-10 relative">
        <div class="grid-section-glow" aria-hidden="true"></div>

        <h2 class="font-display font-bold text-xl sm:text-2xl text-lavender-100 text-center mb-3 animate-[fade-in-up_0.6s_ease-out_both]">
          สำรวจเพิ่มเติม
        </h2>
        <p class="text-text-muted text-sm text-center mb-10 animate-[fade-in-up_0.6s_ease-out_0.1s_both]">
          คุณสมบัติทั้งหมดของเดาใจ
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4 relative z-10">
          <a href="/horoscope" class="action-card group" style="animation-delay: 0.05s;" aria-label="ดูดวงรายวัน — เลือกราศีดูดวงวันนี้">
            <span class="action-icon" aria-hidden="true">🔮</span>
            <h2 class="action-title">ดูดวงรายวัน</h2>
            <p class="action-desc">เลือกราศีดูดวงวันนี้</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="/tarot/daily" class="action-card group" style="animation-delay: 0.1s;" aria-label="จับไพ่ทาโรต์ — เปิดไพ่ 1 ใบประจำวัน">
            <span class="action-icon" aria-hidden="true">🃏</span>
            <h2 class="action-title">จับไพ่ทาโรต์</h2>
            <p class="action-desc">เปิดไพ่ 1 ใบประจำวัน</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="/compatibility" class="action-card group" style="animation-delay: 0.15s;" aria-label="เช็คดวงคู่ — ดูความเข้ากันของคุณกับเขา">
            <span class="action-icon" aria-hidden="true">💕</span>
            <h2 class="action-title">เช็คดวงคู่</h2>
            <p class="action-desc">ดูความเข้ากันของคุณกับเขา</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="/birth-chart" class="action-card group" style="animation-delay: 0.2s;" aria-label="ดูดวงวันเกิด — ราศี ทักษา เลขชีวิต">
            <span class="action-icon" aria-hidden="true">⭐</span>
            <h2 class="action-title">ดูดวงวันเกิด</h2>
            <p class="action-desc">ราศี ทักษา เลขชีวิต</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="/tarot/3-card" class="action-card group" style="animation-delay: 0.25s;" aria-label="ไพ่ 3 ใบ — อดีต ปัจจุบัน อนาคต">
            <span class="action-icon" aria-hidden="true">🃏</span>
            <h2 class="action-title">ไพ่ 3 ใบ</h2>
            <p class="action-desc">อดีต ปัจจุบัน อนาคต</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="/tarot/cards" class="action-card group" style="animation-delay: 0.3s;" aria-label="สารานุกรมไพ่ — ค้นหาความหมายไพ่ 78 ใบ">
            <span class="action-icon" aria-hidden="true">📚</span>
            <h2 class="action-title">สารานุกรมไพ่</h2>
            <p class="action-desc">ค้นหาความหมายไพ่ 78 ใบ</p>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </section>

      <section class="max-w-3xl mx-auto pb-8 pt-4 animate-[fade-in-up_0.6s_ease-out_0.4s_both]">
        <h3 class="font-display font-bold text-sm text-lavender-300 text-center mb-4 tracking-wide">
          ✨ ดูดวงยอดฮิตวันนี้
        </h3>
        <div class="grid grid-cols-3 gap-3">
          {TOP_SIGNS.map((sign, i) => (
            <a
              href="/horoscope"
              class="top-zodiac-card"
              style={`animation-delay: ${0.45 + i * 0.08}s; --glow-color: ${sign.color};`}
            >
              <span class="top-zodiac-rank">#{i + 1}</span>
              <span class="top-zodiac-symbol">{sign.symbol}</span>
              <span class="top-zodiac-name">{sign.name}</span>
              <span class="top-zodiac-hint">{sign.hint}</span>
            </a>
          ))}
        </div>
      </section>

      <footer class="max-w-3xl mx-auto pb-8 pt-8 border-t border-lavender-500/10 animate-[fade-in-up_0.6s_ease-out_0.5s_both]">
        <div class="flex flex-col items-center gap-4 text-center">
          <p class="text-sm text-lavender-300/70 font-display">
            สร้างด้วย ✨ โดยเดาใจ
          </p>
          <p class="text-[11px] text-text-muted/40 leading-relaxed max-w-xs">
            เว็บดูดวงออนไลน์เพื่อความบันเทิง ผลการดูดวงไม่ได้เป็นคำแนะนำทางการแพทย์หรือการเงิน
          </p>
          <p class="text-[11px] text-text-muted/30">
            © 2026 เดาใจ DaoJai — เพื่อนสนิทที่รู้เรื่องดวง
          </p>
        </div>
      </footer>
    </div>
  </div>
</AppLayout>

<style>
  .hero-section {
    min-height: 85vh;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .hero-section {
      min-height: 90vh;
      padding-top: 6rem;
    }
  }

  .hero-title {
    text-shadow:
      0 0 60px rgba(255, 213, 128, 0.3),
      0 0 120px rgba(196, 181, 253, 0.15);
    animation: pulse-glow 4s ease-in-out infinite, fade-in-up 0.6s ease-out both;
  }

  .hero-glow {
    position: absolute;
    top: 35%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 213, 128, 0.1) 0%, rgba(139, 92, 246, 0.05) 40%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  .hero-glow-secondary {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(139, 92, 246, 0.06) 0%, transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }

  .cta-button {
    background: linear-gradient(135deg, var(--color-accent-gold), var(--color-accent-gold-deep));
    color: var(--color-surface-midnight);
    box-shadow: 0 0 30px rgba(255, 213, 128, 0.25), 0 4px 16px rgba(0, 0, 0, 0.3);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 50px rgba(255, 213, 128, 0.4), 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .cta-button:active {
    transform: translateY(0) scale(0.98);
  }

  .card-fan-container {
    perspective: 800px;
  }

  .card-fan {
    transform: rotateX(5deg);
  }

  .spread-section-glow,
  .grid-section-glow {
    position: absolute;
    inset: -40px;
    border-radius: 3rem;
    background: radial-gradient(ellipse at 50% 30%, rgba(139, 92, 246, 0.05), transparent 70%);
    pointer-events: none;
  }

  .spread-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 2rem 1.25rem 1.5rem;
    border-radius: 1.25rem;
    background: rgba(30, 27, 75, 0.4);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(196, 181, 253, 0.1);
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .spread-card:hover {
    background: rgba(30, 27, 75, 0.6);
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .spread-card--gold:hover {
    border-color: rgba(255, 213, 128, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), 0 0 30px rgba(255, 213, 128, 0.1);
  }

  .spread-card--lavender:hover {
    border-color: rgba(196, 181, 253, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), 0 0 30px rgba(196, 181, 253, 0.08);
  }

  .spread-card--sky:hover {
    border-color: rgba(125, 211, 252, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4), 0 0 30px rgba(125, 211, 252, 0.08);
  }

  .spread-card-glow {
    position: absolute;
    top: -30px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 213, 128, 0.08), transparent 70%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .spread-card:hover .spread-card-glow {
    opacity: 1;
  }

  .spread-card-emoji {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    filter: drop-shadow(0 0 8px rgba(255, 213, 128, 0.12));
  }

  .spread-card-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.75rem;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 213, 128, 0.08);
    color: var(--color-accent-gold);
    opacity: 0;
    transform: translateY(4px);
    transition: all 0.3s ease;
  }

  .spread-card:hover .spread-card-arrow {
    opacity: 1;
    transform: translateY(0);
  }

  .action-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    min-height: 130px;
    padding: 1.25rem 1rem;
    border-radius: 1rem;
    background: rgba(30, 27, 75, 0.45);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(196, 181, 253, 0.12);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    animation: fade-in-up 0.6s ease-out both;
    text-decoration: none;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(15, 14, 46, 0.3), 0 0 1px rgba(255, 213, 128, 0.05);
  }

  .action-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 30%,
      rgba(255, 213, 128, 0.06) 0%,
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .action-card:hover::before {
    opacity: 1;
  }

  .action-card:hover {
    background: rgba(30, 27, 75, 0.65);
    border-color: rgba(255, 213, 128, 0.25);
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(15, 14, 46, 0.5),
      0 0 24px rgba(255, 213, 128, 0.08);
  }

  .action-card:active {
    transform: translateY(-1px) scale(0.98);
  }

  .action-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    filter: drop-shadow(0 0 8px rgba(255, 213, 128, 0.15));
  }

  .action-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-lavender-100);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .action-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    flex: 1;
  }

  .action-arrow {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: var(--color-text-muted);
    opacity: 0.3;
    transition: all 0.3s ease;
  }

  .action-card:hover .action-arrow {
    opacity: 0.7;
    color: var(--color-accent-gold);
    transform: translateX(2px);
  }

  .top-zodiac-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1rem 0.75rem;
    border-radius: 1rem;
    background: rgba(30, 27, 75, 0.35);
    border: 1px solid rgba(196, 181, 253, 0.1);
    text-decoration: none;
    transition: all 0.3s ease;
    animation: fade-in-up 0.6s ease-out both;
    position: relative;
    overflow: hidden;
  }

  .top-zodiac-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 2px;
    border-radius: 1px;
    background: var(--glow-color, rgba(255, 213, 128, 0.3));
    opacity: 0.5;
  }

  .top-zodiac-card:hover {
    background: rgba(30, 27, 75, 0.55);
    border-color: rgba(255, 213, 128, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(15, 14, 46, 0.4), 0 0 12px color-mix(in srgb, var(--glow-color) 15%, transparent);
  }

  .top-zodiac-rank {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.65rem;
    color: var(--color-accent-gold);
    opacity: 0.7;
  }

  .top-zodiac-symbol {
    font-size: 1.75rem;
    line-height: 1;
  }

  .top-zodiac-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--color-lavender-100);
  }

  .top-zodiac-hint {
    font-size: 0.65rem;
    color: var(--color-text-muted);
  }

  .star-field-home {
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.4;
  }

  .stars-home-sm, .stars-home-md {
    position: absolute;
    inset: 0;
  }

  .stars-home-sm::after, .stars-home-md::after {
