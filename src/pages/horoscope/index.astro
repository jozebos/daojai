---
import AppLayout from "@/layouts/AppLayout.astro";
import { WESTERN_ZODIAC_SIGNS, type WesternElement } from "@/lib/astrology/zodiac";
import { formatThaiDate } from "@/lib/utils/date";

const today = new Date();
const thaiDate = formatThaiDate(today);

const THAI_MONTH_ABBR: Record<number, string> = {
  1: "ม.ค.", 2: "ก.พ.", 3: "มี.ค.", 4: "เม.ย.", 5: "พ.ค.", 6: "มิ.ย.",
  7: "ก.ค.", 8: "ส.ค.", 9: "ก.ย.", 10: "ต.ค.", 11: "พ.ย.", 12: "ธ.ค.",
};

const ELEMENT_ACCENT: Record<WesternElement, string> = {
  fire: "text-accent-gold",
  earth: "text-sage-green",
  air: "text-lavender-300",
  water: "text-sky",
};

function dateRange(s: typeof WESTERN_ZODIAC_SIGNS[number]): string {
  return `${s.startDay} ${THAI_MONTH_ABBR[s.startMonth]} – ${s.endDay} ${THAI_MONTH_ABBR[s.endMonth]}`;
}

const title = "ดวงรายวัน 12 ราศี • เดาใจ";
const description = `ดูดวงรายวันทุกราศี วันนี้ ${thaiDate} — ความรัก การงาน การเงิน สุขภาพ โชคลาภ พร้อมคำแนะนำจากดวงดาว`;
---

<AppLayout title={title} description={description}>
  <Fragment slot="default">
    <div class="pt-6 pb-12 md:pt-10">

      {/* ── Header ── */}
      <header class="text-center mb-10 animate-[fade-in-up_0.6s_ease-out_both]">
        <p class="text-sm text-text-muted dark:text-text-muted mb-2 tracking-widest uppercase font-medium" aria-label="วันที่">
          {thaiDate}
        </p>
        <h1 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary dark:text-accent-gold mb-3 leading-tight">
          ดวงรายวัน
        </h1>
        <p class="text-base text-text-secondary dark:text-lavender-300/70 max-w-md mx-auto">
          เลือกราศีของคุณ แล้วดูว่าวันนี้ดวงดาวบอกอะไร
        </p>
      </header>

      {/* ── Zodiac Grid ── */}
      <div
        class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5"
        role="list"
        aria-label="ราศีทั้ง 12 ราศี"
      >
        {WESTERN_ZODIAC_SIGNS.map((sign, i) => (
          <a
            href={`/horoscope/${sign.key}`}
            class="zodiac-card group"
            style={`animation-delay: ${i * 0.06}s`}
            role="listitem"
            aria-label={`ราศี${sign.name_th} (${sign.name_en}) — ${dateRange(sign)}`}
          >
            <span class={`zodiac-symbol ${ELEMENT_ACCENT[sign.element]}`} aria-hidden="true">
              {sign.symbol}
            </span>
            <span class="font-display font-bold text-base sm:text-lg text-text-primary dark:text-lavender-100 leading-snug">
              ราศี{sign.name_th}
            </span>
            <span class="text-xs text-text-secondary dark:text-text-muted tracking-wide">
              {sign.name_en}
            </span>
            <span class="text-[11px] text-text-muted dark:text-text-muted/60 mt-1">
              {dateRange(sign)}
            </span>

            {/* hover arrow */}
            <span class="arrow-hint" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

    </div>
  </Fragment>
</AppLayout>

<style>
  .zodiac-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.75rem 1rem 1.5rem;
    border-radius: 1.25rem;
    overflow: hidden;

    /* light mode */
    background: rgba(247, 243, 236, 0.6);
    border: 1px solid rgba(30, 27, 75, 0.06);

    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    animation: fade-in-up 0.6s ease-out both;
  }

  :global(.dark) .zodiac-card {
    background: rgba(30, 27, 75, 0.45);
    border-color: rgba(196, 181, 253, 0.1);
  }

  .zodiac-card:hover {
    transform: translateY(-6px);
    background: rgba(247, 243, 236, 0.85);
    border-color: rgba(30, 27, 75, 0.12);
    box-shadow:
      0 12px 40px rgba(15, 14, 46, 0.08),
      0 4px 12px rgba(15, 14, 46, 0.04);
  }

  :global(.dark) .zodiac-card:hover {
    background: rgba(30, 27, 75, 0.7);
    border-color: rgba(196, 181, 253, 0.22);
    box-shadow:
      0 12px 40px rgba(15, 14, 46, 0.5),
      0 0 20px rgba(196, 181, 253, 0.08);
  }

  .zodiac-symbol {
    font-size: 2.5rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 2px 8px rgba(255, 213, 128, 0.2));
  }

  .zodiac-card:hover .zodiac-symbol {
    transform: scale(1.15) translateY(-2px);
  }

  .arrow-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    opacity: 0;
    transform: translateX(-4px);
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  :global(.dark) .arrow-hint {
    color: var(--color-lavender-300);
  }

  .zodiac-card:hover .arrow-hint {
    opacity: 0.6;
    transform: translateX(0);
  }
</style>
