---
import AppLayout from "@/layouts/AppLayout.astro";
import { TAROT_DECK, getTarotCardById, type TarotSuitKey } from "@/lib/tarot/deck";
import { getCardImageUrl } from "@/lib/tarot/card-images";

export function getStaticPaths() {
  return TAROT_DECK.map((card) => ({
    params: { id: card.id },
  }));
}

const { id } = Astro.params;
const card = getTarotCardById(id);

const ELEMENT_META: Record<string, { label: string; color: string; colorTo: string }> = {
  fire: { label: "ไฟ (Fire)", color: "#F59E0B", colorTo: "#DC2626" },
  water: { label: "น้ำ (Water)", color: "#7DD3FC", colorTo: "#8B5CF6" },
  air: { label: "ลม (Air)", color: "#C4B5FD", colorTo: "#7DD3FC" },
  earth: { label: "ดิน (Earth)", color: "#86EFAC", colorTo: "#F59E0B" },
  spirit: { label: "จิตวิญญาณ (Spirit)", color: "#FFD580", colorTo: "#C4B5FD" },
};

const SUIT_NAMES: Record<TarotSuitKey, string> = {
  wands: "ไม้เท้า (Wands)",
  cups: "ถ้วย (Cups)",
  swords: "ดาบ (Swords)",
  pentacles: "เหรียญ (Pentacles)",
};

const elementInfo = ELEMENT_META[card.element] ?? ELEMENT_META.spirit;
---

<AppLayout title={`${card.name_th} — สารานุกรมไพ่ | เดาใจ`}>
  <section class="pt-6 pb-12 md:pt-12 max-w-2xl mx-auto">

    <a href="/tarot/cards" class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-lavender-300 transition-colors mb-8">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      กลับสารานุกรม
    </a>

    <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 mb-8 animate-[fade-in-up_0.8s_ease-out_both]">
      <div
        class="card-detail-image shrink-0 self-center sm:self-start"
        style={`background: linear-gradient(160deg, ${elementInfo.color}22, ${elementInfo.colorTo}22);`}
      >
        <img
          src={getCardImageUrl(card.id)}
          alt={card.name_th}
          width="320"
          height="480"
          loading="eager"
          style="object-fit: cover; width: 100%; height: 100%; border-radius: inherit; position: absolute; inset: 0;"
        />
        <div
          class="card-detail-element-strip"
          style={`background: linear-gradient(135deg, ${elementInfo.color}, ${elementInfo.colorTo});`}
        ></div>
        <span class="card-detail-number">{card.number}</span>
      </div>

      <div class="flex-1 min-w-0">
        <h1 class="font-display font-bold text-2xl sm:text-3xl text-accent-gold mb-1">{card.name_th}</h1>
        <p class="text-lavender-300/70 text-sm mb-4">{card.name_en}</p>

        <div class="flex flex-wrap gap-2 mb-4">
          <span class="card-detail-tag">
            {card.arcana === "major" ? "Major Arcana" : "Minor Arcana"}
          </span>
          {card.suit && (
            <span class="card-detail-tag">{SUIT_NAMES[card.suit]}</span>
          )}
          <span class="card-detail-tag" style={`border-color: ${elementInfo.color}40; color: ${elementInfo.color};`}>
            {elementInfo.label}
          </span>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
          {card.keywords_th.map((kw) => (
            <span class="card-detail-keyword">{kw}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="space-y-6 animate-[fade-in-up_0.8s_ease-out_0.15s_both]">
      <div class="card-detail-meaning-block">
        <div class="card-detail-meaning-header">
          <span class="card-detail-meaning-indicator card-detail-meaning-indicator--upright"></span>
          <h2 class="font-display font-bold text-base text-lavender-100">ตั้งตรง (Upright)</h2>
        </div>
        <p class="text-sm text-text-on-dark/80 leading-relaxed">{card.upright_meaning_th}</p>
      </div>

      <div class="card-detail-meaning-block">
        <div class="card-detail-meaning-header">
          <span class="card-detail-meaning-indicator card-detail-meaning-indicator--reversed"></span>
          <h2 class="font-display font-bold text-base text-lavender-100">กลับหัว (Reversed)</h2>
        </div>
        <p class="text-sm text-text-on-dark/80 leading-relaxed">{card.reversed_meaning_th}</p>
      </div>
    </div>

    <div class="mt-10 flex items-center gap-3 animate-[fade-in-up_0.8s_ease-out_0.3s_both]">
      <a
        href="/tarot/daily"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent-gold/10 text-accent-gold text-sm font-medium hover:bg-accent-gold/20 transition-colors"
      >
        จับไพ่ประจำวัน
      </a>
      <a
        href="/tarot/3-card"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-lavender-500/20 text-lavender-300 text-sm font-medium hover:bg-lavender-500/10 transition-colors"
      >
        เปิดไพ่ 3 ใบ
      </a>
    </div>

  </section>
</AppLayout>

<style>
  .card-detail-image {
    width: 200px;
    aspect-ratio: 2 / 3;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(196, 181, 253, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 20px rgba(255, 213, 128, 0.08);
    transition: box-shadow 0.3s ease;
  }

  .card-detail-image:hover {
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4), 0 0 30px rgba(255, 213, 128, 0.15);
  }

  .card-detail-element-strip {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    border-radius: 1rem 1rem 0 0;
  }

  .card-detail-number {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.5rem;
    color: rgba(247, 243, 236, 0.3);
  }

  .card-detail-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border: 1px solid rgba(196, 181, 253, 0.15);
    background: rgba(30, 27, 75, 0.3);
  }

  .card-detail-keyword {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-display);
    color: var(--color-accent-gold);
    background: rgba(255, 213, 128, 0.1);
    border: 1px solid rgba(255, 213, 128, 0.2);
  }

  .card-detail-meaning-block {
    padding: 1.25rem;
    border-radius: 1rem;
    background: rgba(30, 27, 75, 0.35);
    border: 1px solid rgba(196, 181, 253, 0.08);
  }

  .card-detail-meaning-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .card-detail-meaning-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .card-detail-meaning-indicator--upright {
    background: var(--color-sage-green);
    box-shadow: 0 0 8px rgba(134, 239, 172, 0.4);
  }

  .card-detail-meaning-indicator--reversed {
    background: var(--color-pink-soft);
    box-shadow: 0 0 8px rgba(252, 165, 165, 0.4);
  }
</style>
