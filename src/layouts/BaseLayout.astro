---
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "เดาใจ - ดูดวง ไพ่ทาโรต์ เช็คดวงคู่ ดวงวันเกิด", ogImage } = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, "https://daojai.com").href;
const ogImageUrl = ogImage ? new URL(ogImage, "https://daojai.com").href : new URL("/favicon.svg", "https://daojai.com").href;

const jsonLdOrganization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "เดาใจ",
  alternateName: "DaoJai",
  url: "https://daojai.com",
  logo: "https://daojai.com/favicon.svg",
  description: "เดาใจ - เพื่อนสนิทที่รู้เรื่องดวง ดูดวง ไพ่ทาโรต์ เช็คดวงคู่ ดวงวันเกิด",
};

const jsonLdWebApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "เดาใจ - DaoJai",
  url: "https://daojai.com",
  applicationCategory: "LifestyleApplication",
  operatingSystem: "Web",
  description: "ดูดวง ไพ่ทาโรต์ เช็คดวงคู่ ดวงวันเกิด — เพื่อนสนิทที่รู้เรื่องดวง",
  inLanguage: "th",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "THB",
  },
};
---

<!doctype html>
<html lang="th" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0F0E2E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- OG Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:site_name" content="เดาใจ - DaoJai" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebApp)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@400;700&family=IBM+Plex+Sans+Thai:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-surface-cream dark:bg-surface-midnight text-text-primary dark:text-text-on-dark font-sans antialiased transition-colors duration-300">
    <slot />
  </body>
</html>

